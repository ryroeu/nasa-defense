# Copy this file to `.env` for local runs. `.env` is gitignored and never committed.

# --- NASA API key (REQUIRED) --------------------------------------------------
# Get a free key in seconds at https://api.nasa.gov/ .
# The watcher hard-fails at startup if this is not set — no DEMO_KEY fallback.
# (In GitHub Actions, set it as the NASA_API_KEY repo secret instead of using .env.)
NASA_API_KEY=your-key-here

# --- GitHub (only for a REAL local run that writes Issues) --------------------
# Provided automatically inside GitHub Actions; set them locally to post Issues.
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPOSITORY=your-user/nasa-defense

# --- Optional fan-out channels (each inactive unless its value is set) ---------
# FANOUT_WEBHOOK_URL=https://example.com/hook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=nasa-defense@example.com
# SMTP_TO=you@example.com
